generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Employee {
  id                    String    @id @default(cuid())
  name                  String
  email                 String    @unique
  passwordHash          String
  role                  Role      @default(EMPLOYEE)
  title                 String?
  phone                 String?
  startDate             DateTime?
  photoUrl              String?
  isActive              Boolean   @default(true)
  defaultPeriodStartDay Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  timesheets          TimesheetWeek[]
  timesheetReviews    TimesheetWeek[]  @relation("TimesheetReviewer")
  leaveRequests       LeaveRequest[]
  leaveReviews        LeaveRequest[]   @relation("LeaveReviewer")
  leaveBalances       LeaveBalance[]
  expenseReports      ExpenseReport[]
  expenseReviews      ExpenseReport[]  @relation("ExpenseReviewer")
  reportPeriods       ReportPeriod[]
  reportPeriodReviews ReportPeriod[]   @relation("PeriodReviewer")
}

enum Role {
  ADMIN
  EMPLOYEE
}

model Project {
  id         String        @id @default(cuid())
  name       String
  clientName String?
  code       String?       @unique
  status     ProjectStatus @default(ACTIVE)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  entries      TimesheetEntry[]
  expenseItems ExpenseItem[]
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
}

model TimesheetWeek {
  id             String          @id @default(cuid())
  employeeId     String
  weekStartDate  DateTime        // Monday of the week (normalized to 00:00:00 UTC)
  reportPeriodId String?
  status         TimesheetStatus @default(DRAFT)
  reviewedById   String?
  reviewComment  String?
  submittedAt    DateTime?
  reviewedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  employee     Employee      @relation(fields: [employeeId], references: [id])
  reviewer     Employee?     @relation("TimesheetReviewer", fields: [reviewedById], references: [id])
  reportPeriod ReportPeriod? @relation(fields: [reportPeriodId], references: [id])
  entries      TimesheetEntry[]

  @@unique([employeeId, weekStartDate])
}

model ReportPeriod {
  id            String          @id @default(cuid())
  employeeId    String
  startDate     DateTime
  endDate       DateTime
  status        TimesheetStatus @default(DRAFT)
  submittedAt   DateTime?
  reviewedAt    DateTime?
  reviewedById  String?
  reviewComment String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  rowOrder  Json?

  employee Employee        @relation(fields: [employeeId], references: [id])
  reviewer Employee?       @relation("PeriodReviewer", fields: [reviewedById], references: [id])
  weeks    TimesheetWeek[]
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

model TimesheetEntry {
  id              String   @id @default(cuid())
  timesheetWeekId String
  projectId       String
  phase           String   @default("")
  date            DateTime // specific calendar day (normalized to 00:00:00 UTC)
  hours           Float    @default(0)
  absenceCode     String?  // H, V, S, C, B, R, H/D
  notes           String?

  timesheetWeek TimesheetWeek @relation(fields: [timesheetWeekId], references: [id], onDelete: Cascade)
  project       Project       @relation(fields: [projectId], references: [id])

  @@unique([timesheetWeekId, projectId, phase, date])
}

model LeaveRequest {
  id            String      @id @default(cuid())
  employeeId    String
  type          LeaveType
  startDate     DateTime
  endDate       DateTime
  status        LeaveStatus @default(PENDING)
  reviewedById  String?
  reviewComment String?
  createdAt     DateTime    @default(now())
  reviewedAt    DateTime?

  employee Employee         @relation(fields: [employeeId], references: [id])
  reviewer Employee?        @relation("LeaveReviewer", fields: [reviewedById], references: [id])
  days     LeaveRequestDay[]
}

model LeaveRequestDay {
  id             String       @id @default(cuid())
  leaveRequestId String
  date           DateTime
  halfDay        Boolean      @default(false)
  reason         String?

  leaveRequest LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)

  @@index([leaveRequestId])
}

enum LeaveType {
  VACATION
  SICK
  PERSONAL
  OTHER
  COMP_DAY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model LeaveBalance {
  id         String    @id @default(cuid())
  employeeId String
  year       Int
  type       LeaveType
  totalDays  Float
  usedDays   Float     @default(0)

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, year, type])
}

model ExpenseReport {
  id            String        @id @default(cuid())
  employeeId    String
  month         Int
  year          Int
  status        ExpenseStatus @default(DRAFT)
  advanceAmount Float         @default(0)
  notes         String?
  reviewedById  String?
  reviewComment String?
  submittedAt   DateTime?
  reviewedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  employee  Employee          @relation(fields: [employeeId], references: [id])
  reviewer  Employee?         @relation("ExpenseReviewer", fields: [reviewedById], references: [id])
  items     ExpenseItem[]
  documents ExpenseDocument[]

  @@unique([employeeId, month, year])
}

model ExpenseItem {
  id               String          @id @default(cuid())
  expenseReportId  String
  projectId        String
  date             DateTime
  category         ExpenseCategory
  otherDescription String?
  description      String
  amount           Float

  expenseReport ExpenseReport @relation(fields: [expenseReportId], references: [id], onDelete: Cascade)
  project       Project       @relation(fields: [projectId], references: [id])
}

model ExpenseDocument {
  id              String   @id @default(cuid())
  expenseReportId String
  fileName        String
  fileUrl         String
  fileSize        Int?
  mimeType        String?
  uploadedAt      DateTime @default(now())

  expenseReport ExpenseReport @relation(fields: [expenseReportId], references: [id], onDelete: Cascade)
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum ExpenseCategory {
  TRANSPORTATION
  MEALS
  MEALS_USA
  MEALS_CHINA
  ACCOMMODATION
  OTHER
}
